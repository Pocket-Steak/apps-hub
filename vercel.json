{
  "redirects": [
    {
      "source": "/",
      "destination": "/apps/",
      "permanent": false
    },
    {
      "source": "/apps",
      "destination": "/apps/",
      "permanent": false
    },
    {
      "source": "/family",
      "destination": "/family/",
      "permanent": false
    },
    {
      "source": "/family-tst",
      "destination": "/family-tst/",
      "permanent": false
    },
    {
      "source": "/countdown",
      "destination": "/countdown/",
      "permanent": false
    },
    {
      "source": "/settings",
      "destination": "/family/settings.html",
      "permanent": false
    },
    {
      "source": "/tst-settings",
      "destination": "/family-tst/settings.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
