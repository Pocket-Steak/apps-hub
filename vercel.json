{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/family/?$",
      "dest": "/family/index.html"
    },
    {
      "src": "^/family-tst/?$",
      "dest": "/family-tst/index.html"
    },
    {
      "src": "^/countdown/?$",
      "dest": "/countdown/index.html"
    }
  ]
}
